#!/bin/bash
# pre-push hook: run EditMode + PlayMode tests + check runtime errors before push
# Skip with: git push --no-verify

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"

GREEN='\033[0;32m'
RED='\033[0;31m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

EDITOR_LOG="$HOME/Library/Logs/Unity/Editor.log"

# --- 1. Record Editor.log baseline + clear console ---
BASELINE=0
if [ -f "$EDITOR_LOG" ]; then
    BASELINE=$(wc -l < "$EDITOR_LOG")
fi

PORT=$(python3 -c "import json; print(json.load(open('$SCRIPT_DIR/Temp/eval_server.json'))['port'])" 2>/dev/null || true)
if [ -n "$PORT" ]; then
    curl -s --connect-timeout 3 --max-time 5 -X POST "http://localhost:$PORT/" \
        -d '{"command":"clear-console"}' -H 'Content-Type: application/json' >/dev/null 2>&1 || true
fi

# --- 2. Run tests ---
echo -e "${CYAN}[pre-push] Running unit/integration tests...${NC}"

if ! "$SCRIPT_DIR/scripts/unity-unit-test.sh"; then
    echo -e "${RED}[pre-push] Tests failed, blocking push${NC}"
    echo -e "${RED}[pre-push] Fix tests and retry, or use git push --no-verify to skip${NC}"
    exit 1
fi

# --- 3. Check runtime errors during tests ---
echo -e "${CYAN}[pre-push] Checking runtime errors...${NC}"

ERROR_REPORT_FILE=$(mktemp)
trap "rm -f '$ERROR_REPORT_FILE'" EXIT

if [ -f "$EDITOR_LOG" ]; then
    tail -n +$((BASELINE + 1)) "$EDITOR_LOG" | awk '
    /^(NullReferenceException|MissingReferenceException|ArgumentException|InvalidOperationException|IndexOutOfRangeException|KeyNotFoundException|ArgumentNullException|ArgumentOutOfRangeException|NotSupportedException|StackOverflowException|ObjectDisposedException|FormatException|OverflowException)/ {
        print "ERROR: " $0
        for (i = 0; i < 3; i++) {
            if ((getline line) > 0 && line ~ /^  at |\(at /)
                print "  TRACE: " line
            else break
        }
        next
    }
    /^UnityEngine\.Debug:LogError/ {
        if (last_msg != "") {
            print "ERROR: " last_msg
            if ((getline line) > 0 && line ~ / \(at /)
                print "  TRACE: " line
        }
        last_msg = ""
        last_caller = ""
        next
    }
    /^UnityEngine\.StackTraceUtility|^UnityEngine\.DebugLogHandler|^UnityEngine\.Logger/ { next }
    /^  at / { next }
    /^$/ { next }
    /^\(Filename:/ { next }
    / \(at / {
        if (last_msg != "" && last_caller == "") last_caller = $0
        next
    }
    { last_msg = $0; last_caller = "" }
    ' > "$ERROR_REPORT_FILE"
fi

if [ -s "$ERROR_REPORT_FILE" ]; then
    ERROR_COUNT=$(grep -c "^ERROR:" "$ERROR_REPORT_FILE" || true)
    echo -e "${YELLOW}[pre-push] Warning: tests passed but found $ERROR_COUNT runtime error(s):${NC}"
    echo -e "${YELLOW}────────────────────────────────────────${NC}"
    while IFS= read -r line; do
        case "$line" in
            "ERROR: "*)  echo -e "${RED}  ${line#ERROR: }${NC}" ;;
            "  TRACE: "*)  echo -e "${YELLOW}    ${line#  TRACE: }${NC}" ;;
        esac
    done < "$ERROR_REPORT_FILE"
    echo -e "${YELLOW}────────────────────────────────────────${NC}"
    echo -e "${YELLOW}[pre-push] Please check if these are expected (e.g., Assert.Throws) or real bugs.${NC}"
    echo ""
fi

echo -e "${GREEN}[pre-push] All tests passed, push allowed${NC}"
exit 0
