{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/scripts/hooks/pre-push-test.sh",
            "timeout": 300,
            "statusMessage": "Pre-push test gate..."
          }
        ]
      }
    ]
  }
}
