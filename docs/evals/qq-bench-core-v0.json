{
  "schema_version": 1,
  "benchmark_family": "qq-bench-core",
  "benchmark_version": "0.1",
  "suite_id": "qq-bench-core-v0",
  "description": "QQ-Bench Core v0 public suite for controller routing, policy escalation, worktree lifecycle, and recovery behavior.",
  "tasks": [
    {
      "task_id": "controller-routing-prototype",
      "runner": "timeline_case",
      "summary": "Prototype mode stays light and routes directly when no artifacts or blockers exist.",
      "fixture": {
        "local_config": {
          "work_mode": "prototype",
          "policy_profile": "feature"
        }
      },
      "expect": {
        "work_mode": "prototype",
        "policy_profile": "feature",
        "recommended_next": "prototype_direct"
      }
    },
    {
