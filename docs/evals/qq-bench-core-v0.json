            "policy_profile": "core"
          },
          "write_files": [
            {
              "path": "PolicyEscalation.cs",
              "content": "using UnityEngine;\n\npublic class PolicyEscalation : MonoBehaviour {}\n"
            }
          ],
          "record_stages": [
            {
              "stage": "review_gate",
              "status": "not_started",
              "summary": "policy escalation gate not started"
