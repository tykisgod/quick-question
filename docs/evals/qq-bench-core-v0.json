    {
      "task_id": "resume-after-compile-failure",
      "runner": "timeline_case",
      "summary": "Controller stays on compile repair until a fresh successful compile exists, then resumes the path.",
      "fixture": {
        "local_config": {
          "work_mode": "feature",
          "policy_profile": "feature"
        }
      },
      "steps": [
        {
          "write_files": [
            {
              "path": "CompileRecovery.cs",
              "content": "using UnityEngine;\n\npublic class CompileRecovery : MonoBehaviour {}\n"
            }
          ],
          "record_stages": [
            {
              "stage": "compile",
              "status": "failed",
              "summary": "compile recovery failed"
            }
          ],
          "expect": {
            "last_compile_status": "failed",
            "recommended_next": "fix_compile"
          }
        },
        {
          "record_stages": [
            {
              "stage": "compile",
              "status": "passed",
              "summary": "compile recovery passed"
            }
          ],
          "expect": {
            "last_compile_status": "passed",
            "recommended_next": "/qq:test"
          }
        }
      ]
