        "baseline_files": [
          {
            "path": "Assets/Scripts/PlayerLocator.cs",
            "content": "using UnityEngine;\n\npublic class PlayerLocator : MonoBehaviour\n{\n    void Update()\n    {\n        var body = GetComponent<Rigidbody>();\n        if (gameObject.tag == \"Player\")\n        {\n            body.velocity = Vector3.zero;\n        }\n    }\n}\n"
          }
        ]
