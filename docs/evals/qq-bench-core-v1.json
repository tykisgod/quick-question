      "runner": "code_fixture_case",
      "summary": "A real feature edit removes hot-path GetComponent and tag string checks, then routes to targeted testing.",
      "prompt": "Cache component access outside Update and replace string tag checks with CompareTag while keeping the change local.",
      "fixture": {
        "local_config": {
          "work_mode": "feature",
          "policy_profile": "feature"
